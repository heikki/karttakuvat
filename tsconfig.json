{
  "extends": "@total-typescript/tsconfig/bundler",
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ESNext", "DOM"],
    "types": ["bun"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "paths": {
      "@common/*": ["./src/client/common/*"],
      "@components/*": ["./src/client/components/*"],
      "@client/*": ["./src/client/*"],
      "@server/*": ["./src/server/*"],
      "@native/*": ["./resources/native/*"]
    }
  },
  "exclude": ["node_modules"]
}
