{
  "extends": "@total-typescript/tsconfig/bundler",
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ESNext", "DOM"],
    "types": ["bun"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@common/*": ["src/common/*"],
      "@components/*": ["src/components/*"]
    }
  }
}
